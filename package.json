{
  "name": "localbridge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api:dev": "bun api/server.js",
    "api:go": "cd go-api && go run -ldflags=-linkmode=external .",
    "api:go:package": "./go-api/scripts/package.sh",
    "icons:web": "./worker/scripts/generate-web-icons.sh",
    "macos:dev": "cd macos-status-app && swift run",
    "macos:package": "./macos-status-app/scripts/package-app.sh",
    "macos:run": "./macos-status-app/scripts/package-app.sh && open macos-status-app/dist/LocalBridge.app",
    "worker:dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "hono": "^4.7.2"
  },
  "devDependencies": {
    "vitest": "^3.0.8",
    "wrangler": "^4.7.1"
  }
}
